            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?status=&priority=&dueDateFrom=&dueDateTo=&search=&sort=newest&page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tasks"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "",
                  "description": "TODO, IN_PROGRESS, or COMPLETED"
                },
                {
                  "key": "priority",
                  "value": "",
                  "description": "LOW, MEDIUM, or HIGH"
                },
                {
                  "key": "dueDateFrom",
                  "value": "",
                  "description": "ISO date string"
                },
                {
                  "key": "dueDateTo",
                  "value": "",
                  "description": "ISO date string"
                },
                {
                  "key": "search",
                  "value": ""
                },
                {
                  "key": "sort",
                  "value": "newest",
                  "description": "newest, oldest, dueDateAsc, or dueDateDesc"
